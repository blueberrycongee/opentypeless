{
  "name": "@opentypeless/desktop",
  "productName": "OpenTypeless",
  "version": "0.1.0",
  "description": "Desktop-first open source AI dictation shell for OpenTypeless.",
  "main": ".webpack/main",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "ai:setup": "./scripts/setup-local-ai.sh",
    "verify:e2e": "node --import tsx ./scripts/verify-e2e.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "keywords": [
    "electron",
    "desktop",
    "dictation",
    "ai"
  ],
  "author": "OpenTypeless",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@electron/fuses": "^2.1.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.0",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "css-loader": "^7.1.4",
    "electron": "^41.0.2",
    "eslint": "^9.39.4",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "globals": "^16.5.0",
    "node-loader": "^2.1.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "i18next": "^25.8.18"
  }
}
